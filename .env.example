# Copy to .env and fill in. In Docker, values come from the host/secrets, not this file.

# SQLite database file. Local dev: a path like local.db. In Docker: the mounted volume path.
DATABASE_URL=local.db

# Public origin of the app. Drives SvelteKit CSRF, Better Auth baseURL + trustedOrigins, secure-
# cookie gating, and adapter-node URL construction behind the tunnel. The https:// in prod is what
# flips Secure cookies on; keep this http://localhost in dev or browsers won't store the cookie.
# Local: http://localhost:5173 — Production: https://dominatus.larront.com
ORIGIN=http://localhost:5173

# pino log level: trace|debug|info|warn|error|fatal. Defaults to debug in dev, info in prod.
LOG_LEVEL=

# Auth rate limiting. Unset = on in prod (NODE_ENV=production), off in dev/tests — the default.
# 'true' force-enables for a localhost smoke test; 'false' is a prod kill-switch.
RATE_LIMIT_ENABLED=

# Better Auth signing secret. Generate with: openssl rand -base64 32
# Use a unique, high-entropy value in production. Never commit the real one.
BETTER_AUTH_SECRET=replace-me

# --- Wired up in later checklist chunks ---

# Resend transactional email (https://resend.com)
RESEND_API_KEY=
# Sender address — must be on a domain verified in Resend. Defaults to Resend's sandbox sender.
EMAIL_FROM="Dominatus <noreply@yourdomain.com>"

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
